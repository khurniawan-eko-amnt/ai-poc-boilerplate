# =============================================================================
# Supabase Self-Hosted — Environment Configuration (Example)
# =============================================================================
# Instructions:
#   1. cp .env.example .env
#   2. Run the key generator: sh utils/generate-keys.sh (or manually fill in)
#   3. docker compose up -d
# =============================================================================

# ─── Compose File ──────────────────────────────────────────
COMPOSE_FILE=docker-compose.yml

# ─── Secrets — CHANGE THESE ─────────────────────────────────
POSTGRES_PASSWORD=change-me-to-a-strong-password
JWT_SECRET=change-me-to-a-64-char-random-string
ANON_KEY=change-me-a-valid-hs256-jwt-for-anon-role
SERVICE_ROLE_KEY=change-me-a-valid-hs256-jwt-for-service-role
SECRET_KEY_BASE=change-me-to-a-64-char-random-key
REALTIME_DB_ENC_KEY=change-me-16-chars
VAULT_ENC_KEY=change-me-32-chars-exactly
PG_META_CRYPTO_KEY=change-me-32-chars-min
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change-me-to-a-strong-password

# New opaque API keys (leave empty to use legacy HS256 only)
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
JWT_JWKS={\"keys\":[]}
JWT_KEYS=[]

# S3 protocol keys for storage
S3_PROTOCOL_ACCESS_KEY_ID=change-me-32-hex-chars
S3_PROTOCOL_ACCESS_KEY_SECRET=change-me-64-hex-chars

# ─── Ports ──────────────────────────────────────────────────
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443
POSTGRES_PORT=5432

# ─── URLs — Replace with your VM's IP/domain ──────────────
SUPABASE_PUBLIC_URL=http://localhost:8000
API_EXTERNAL_URL=http://localhost:8000/auth/v1
SITE_URL=http://localhost:80
ADDITIONAL_REDIRECT_URLS=

# ─── Studio ────────────────────────────────────────────────
STUDIO_DEFAULT_ORGANIZATION=Default Organization
STUDIO_DEFAULT_PROJECT=Default Project
OPENAI_API_KEY=

# ─── Database ──────────────────────────────────────────────
POSTGRES_HOST=db
POSTGRES_DB=postgres

# ─── Auth ──────────────────────────────────────────────────
JWT_EXPIRY=3600
DISABLE_SIGNUP=false
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=true
ENABLE_ANONYMOUS_USERS=false

MAILER_URLPATHS_CONFIRMATION="/auth/v1/verify"
MAILER_URLPATHS_INVITE="/auth/v1/verify"
MAILER_URLPATHS_RECOVERY="/auth/v1/verify"
MAILER_URLPATHS_EMAIL_CHANGE="/auth/v1/verify"
SMTP_ADMIN_EMAIL=admin@example.com
SMTP_HOST=supabase-mail
SMTP_PORT=2500
SMTP_USER=fake_mail_user
SMTP_PASS=fake_mail_password
SMTP_SENDER_NAME=Supabase Mail

ENABLE_PHONE_SIGNUP=false
ENABLE_PHONE_AUTOCONFIRM=false

# ─── Storage ────────────────────────────────────────────────
GLOBAL_S3_BUCKET=stub
REGION=stub
STORAGE_TENANT_ID=stub

# ─── API (PostgREST) ──────────────────────────────────────
PGRST_DB_SCHEMAS=public,storage,graphql_public
PGRST_DB_MAX_ROWS=1000
PGRST_DB_EXTRA_SEARCH_PATH=public,extensions

# ─── Functions ─────────────────────────────────────────────
FUNCTIONS_VERIFY_JWT=false

# ─── Pooler / Supavisor ───────────────────────────────────
POOLER_TENANT_ID=pooler
POOLER_PROXY_PORT_TRANSACTION=6543
POOLER_DEFAULT_POOL_SIZE=20
POOLER_MAX_CLIENT_CONN=100
POOLER_DB_POOL_SIZE=5

# ─── Misc ──────────────────────────────────────────────────
DOCKER_SOCKET_LOCATION=/var/run/docker.sock
IMGPROXY_AUTO_WEBP=true